<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # NOTE: product images are served by GET /api/product-images/{shop}/{file}
    # (ProductController::serveImage), not through /storage + the public/storage
    # symlink. Shared hosts (Bluehost/cPanel and similar) commonly disable
    # FollowSymLinks, which makes Apache 403 on the symlinked path even though
    # the file exists and is readable — streaming it through PHP sidesteps
    # that entirely. There used to be an `Alias /storage ...` block here, but
    # `Alias` is not a valid directive inside .htaccess (server-config/vhost
    # only) — on hosts with strict AllowOverride checking, an invalid
    # directive here can 500 the *entire* app, not just image requests, so it
    # was removed rather than left as dead (and risky) weight.

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>